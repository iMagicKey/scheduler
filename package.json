        "chai": "latest",
        "eslint": "^9.24.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-n": "^17.24.0",
        "eslint-plugin-promise": "^7.2.1",
        "globals": "^16.0.0",
        "prettier": "^3.8.1"
